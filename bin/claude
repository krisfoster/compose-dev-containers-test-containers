#!/usr/bin/env bash
# Project-local wrapper: run Claude Code inside a Docker sbx sandbox.
# Docs: https://docs.docker.com/ai/sandboxes/agents/claude-code/
#
# Inside sbx, the default startup command is `claude --dangerously-skip-permissions`,
# so nothing extra is needed on that front. Args passed here are forwarded to
# `sbx run claude` and appended after the defaults when they start with `-`.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

fail() {
  echo "✗ $1" >&2
  echo >&2
  echo "  Run ./bin/onboard for a guided walkthrough." >&2
  exit 1
}

# --- preflight (fast, no network) ---

command -v sbx >/dev/null \
  || fail "sbx not installed. brew install docker/tap/sbx"

[ -n "${SBX_MCP_URL:-}" ] \
  || fail "SBX_MCP_URL not set. MCP won't work until the daemon sees this env var."

# Required MCP servers must be registered before --static-mcp will accept them.
missing=()
registered="$(sbx mcp ls 2>/dev/null || true)"
for srv in github context7; do
  grep -qE "(^|[[:space:]])${srv}([[:space:]]|$)" <<<"$registered" || missing+=("$srv")
done
if [ "${#missing[@]}" -gt 0 ]; then
  fail "MCP servers not registered: ${missing[*]}. Register with ./bin/setup-mcp"
fi

# Warn if git remotes use SSH. sbx's HTTPS proxy handles GitHub credentials
# automatically; outbound SSH requires an extra network policy rule plus a
# key loaded in the host launchd SSH agent (the forwarded 1Password agent
# does not expose identities inside the sandbox).
if git -C "$REPO_ROOT" rev-parse --git-dir >/dev/null 2>&1; then
  ssh_remotes="$(git -C "$REPO_ROOT" remote -v 2>/dev/null \
    | awk '$2 ~ /^(git@|ssh:\/\/)/ {print $1}' | sort -u | paste -sd, - || true)"
  if [ -n "$ssh_remotes" ]; then
    echo "⚠  git remote(s) use SSH: $ssh_remotes" >&2
    echo "   sbx routes git through its HTTPS proxy. To switch:" >&2
    echo "     git remote set-url <name> https://github.com/OWNER/REPO.git" >&2
  fi
fi

# --- runtime setup ---

# Refresh the `github` service secret from the host's authenticated gh CLI.
# Stored in the macOS Keychain. Per Docker Sandboxes docs, a global (-g)
# service secret is captured when a sandbox is created; if the token rotates,
# `sbx rm <sandbox>` and re-launch to pick up the new value. Refreshing on
# every launch is still worthwhile because the next fresh sandbox will use
# whatever is in the store at creation time.
# The prior stdin-piped form silently cancelled the overwrite prompt, so this
# uses `-f -t` for a reliable non-interactive update.
if command -v gh >/dev/null && gh auth token >/dev/null 2>&1; then
  sbx secret set -g -f -t "$(gh auth token)" github >/dev/null
fi

# --static-mcp and --kit are create-time flags; sbx rejects them when
# re-attaching to an existing sandbox. Only pass them on the first run.
# The gsd-plugin kit installs the gsd-core Claude Code plugin at creation
# time — .claude/settings.json only *declares* it; Claude Code doesn't
# auto-install from that declaration, and plugin state lives in the
# sandbox's own container filesystem, so it never survives recreation
# otherwise.
SANDBOX_NAME="claude-$(basename "$REPO_ROOT")"

# --- Publish sandbox service ports to the host ---------------------------------------
# Services running inside the sandbox are NOT reachable from the host until their port
# is published with `sbx ports <name> --publish HOST:SANDBOX`. We publish two:
#
#   • WEB_PORT (default 8080, read from .env) — the Crossy Whale web app.
#       docker-compose.yml maps "${WEB_PORT}:8080", so once `docker compose up` runs
#       inside the sandbox the game is reachable at http://localhost:$WEB_PORT.
#
#   • NGROK_INSPECT_PORT (4040, fixed) — ngrok's local web inspector (shows the current
#       public tunnel URL and a live request log). docker-compose.yml maps "4040:4040"
#       on the `ngrok` service, which only runs under `docker compose --profile public
#       up`. Publishing 4040 unconditionally is harmless: until the ngrok service is up
#       the forwarded port simply has nothing to connect to.
#
# Notes / caveats:
#   • `sbx ports` targets an EXISTING sandbox, so this runs only on the re-attach path.
#     On the very first launch the sandbox is created by the `exec sbx run` below (and
#     exec never returns), so nothing is published that first time — it happens from the
#     next launch onward, or run the commands printed below once the sandbox is up.
#   • Both publishes are idempotent and guarded with `|| true`: an already-published
#     port, a host-side port clash, or any sbx hiccup must never block launching Claude.
#   • HOST and SANDBOX port numbers are kept identical (e.g. 8080:8080) for predictability.
WEB_PORT="$(sed -n 's/^[[:space:]]*WEB_PORT=[[:space:]]*//p' "$REPO_ROOT/.env" 2>/dev/null | tail -1 | tr -d '\042\047 ' || true)"
WEB_PORT="${WEB_PORT:-8080}"
NGROK_INSPECT_PORT=4040   # fixed: docker-compose.yml hardcodes 4040:4040 on the ngrok service

if sbx ls -q 2>/dev/null | grep -qxF "$SANDBOX_NAME"; then
  sbx ports "$SANDBOX_NAME" --publish "${WEB_PORT}:${WEB_PORT}/tcp"                     >/dev/null 2>&1 || true
  sbx ports "$SANDBOX_NAME" --publish "${NGROK_INSPECT_PORT}:${NGROK_INSPECT_PORT}/tcp" >/dev/null 2>&1 || true
  echo "→ app:           http://localhost:${WEB_PORT}   (once 'docker compose up' is running inside)"
  echo "→ ngrok inspect: http://localhost:${NGROK_INSPECT_PORT}   (only under 'docker compose --profile public up')"
  exec sbx run claude "$@"
else
  echo "ℹ  first launch — the sandbox is being created now; expose its services to your host with:"
  echo "     sbx ports $SANDBOX_NAME --publish ${WEB_PORT}:${WEB_PORT}/tcp                     # web app"
  echo "     sbx ports $SANDBOX_NAME --publish ${NGROK_INSPECT_PORT}:${NGROK_INSPECT_PORT}/tcp   # ngrok inspector (public profile only)"
  echo "   (both are published automatically on your next '$0' launch.)"
  exec sbx run claude \
    --static-mcp github,context7 \
    --kit "$REPO_ROOT/kits/spec-kit" \
    "$@"
fi
