# Local port the webserver publishes the web app on. Change this if 8080 is taken.
WEB_PORT=8080

# ngrok authtoken (https://dashboard.ngrok.com/get-started/your-authtoken).
# Only required when running with `docker compose --profile public up` for a public URL;
# local-only hosting works without it.
# The static domain and upstream are configured in ngrok.yml.
NGROK_AUTHTOKEN=

# Secret used to HMAC-sign visitor access grant cookies. Set this to a long random value for
# any real/public run; the default below is fine for local dev only.
GRANT_COOKIE_SECRET=dev-only-change-me

# How long a QR code stays valid before it expires on its own (Go duration syntax, e.g. 15m, 1h).
QR_WINDOW_TTL=15m

# Shared secret the game client must present when submitting a score to the leaderboard API.
# Set this to a long random value for any real/public run; the default below is fine for local
# dev only. The server injects this into the served game page so the client never needs it typed
# in manually.
LEADERBOARD_API_SECRET=dev-only-change-me
