# =============================================================================
# Ports
# =============================================================================

# Host port nginx listens on (the primary public entry point for the demo stack).
# Change this if port 80 is already in use on your machine.
# If you change NGINX_PORT, you MUST also update COMMITS_SERVICE_URL and
# SCORES_SERVICE_URL below so the browser can reach the microservices.
NGINX_PORT=80

# Host port for direct access to the Go app, bypassing nginx.
# Useful for debugging; normal traffic should go through nginx on NGINX_PORT.
WEB_PORT=8080

# =============================================================================
# Service URLs (browser-visible)
# =============================================================================
# These URLs are injected into the leaderboard page so the browser knows where
# to fetch live scores and commits. They must be reachable FROM the browser,
# so they use localhost and the nginx host port (not internal Docker hostnames).
#
# If NGINX_PORT=80 (the default), leave these as http://localhost.
# If you changed NGINX_PORT to e.g. 8081, set these to http://localhost:8081.

COMMITS_SERVICE_URL=http://localhost
SCORES_SERVICE_URL=http://localhost

# =============================================================================
# Leaderboard
# =============================================================================

# Number of top scores shown on the leaderboard. Defaults to 10.
SCORES_LIMIT=10

# =============================================================================
# QR gate
# =============================================================================

# Secret used to HMAC-sign visitor access grant cookies (cw_grant).
# Set this to a long random value for any real/public run.
# The default in docker-compose is fine for local dev only.
GRANT_COOKIE_SECRET=dev-only-change-me

# How long a QR code stays valid before it expires (Go duration syntax: 15m, 1h, etc.).
QR_WINDOW_TTL=15m

# =============================================================================
# ngrok (public mode only)
# =============================================================================
# Only required when running with `docker compose --profile public up`.
# Local-only hosting works without any of these.

# Your ngrok authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Optional: static ngrok domain so the public URL stays the same across restarts.
# Without this, ngrok generates a new random URL on every restart — previously
# scanned QR codes stop working when the URL changes.
# Claim a free static domain at https://dashboard.ngrok.com/domains
# Example: NGROK_DOMAIN=yourname.ngrok.app
NGROK_DOMAIN=
